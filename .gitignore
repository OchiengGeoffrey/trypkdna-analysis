# ============================================================
# LARGE REGENERABLE DATA - DO NOT TRACK
# ============================================================

# BLAST databases (regenerable from source FASTA)
data/genomes/blastdb/

# SRA downloads and conversions (regenerable from accessions)
data/sra/
data/fastq/
*.sra
*.sra.vdbcache
SRR*/

# Analysis results (regenerable from phase code)
01_comparative_genomics/results/
02_phylogenetics/results/
03_transcriptomics/results/
04_integration/results/

# BUSCO and FastQC intermediate/cache files
busco_downloads/
*/busco_downloads/
00_preflight/results/busco/
00_preflight/results/fastqc/*_fastqc/
00_preflight/results/fastqc/multiqc_data/

# Tool logs (regenerable)
*.log
logs/
tmp/

# ============================================================
# ALLOW EXCEPTIONS (source data and validation results)
# ============================================================

# Source genomes and sequences (DO TRACK)
!data/
!data/genomes/
!data/genomes/*.fasta
!data/genomes/*.fa
!data/genomes/*.fasta.gz
!data/genomes/*.fa.gz

# Phase 0 validation results (DO TRACK - small, prove infrastructure works)
!00_preflight/results/
!00_preflight/results/blast/
!00_preflight/results/blast/*.tsv

# Phase 0 documentation (DO TRACK)
!00_preflight/*.md
!00_preflight/*.csv

